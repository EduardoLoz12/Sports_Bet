# ─── Football Data APIs ────────────────────────────────────────────────────
API_FOOTBALL_KEY=
RAPIDAPI_HOST=
FOOTBALL_DATA_KEY=

# ─── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Betano Peru ───────────────────────────────────────────────────────────
BETANO_USER=
BETANO_PASS=

# ─── Staking (Soles) ───────────────────────────────────────────────────────
BANKROLL_START=
STAKE_HIGH=
STAKE_MED=
STAKE_LOW=

# ─── AI (optional — news summarization) ────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Server ────────────────────────────────────────────────────────────────
PORT=
ENV=
SERVER_HOST=
SERVER_USER=
SERVER_PASSWORD=
SERVER_BOT_PATH=
SERVER_DASHBOARD_URL=

# ─── Reddit sentiment (fetch_reddit_sentiment.py) ──────────────────────────
# Create a free "script" app at reddit.com/prefs/apps (type: script).
# ANTHROPIC_API_KEY (above) is also required for Claude Haiku analysis.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sports-agent/1.0 by your_reddit_username

# ─── Supabase (Vercel dashboard read replica) ──────────────────────────────
# Postgres connection string from Supabase Project Settings → Database →
# Connection string → URI (pooler, port 6543).
# Set on BOTH Hetzner (sync_to_supabase.py push target) AND Vercel (dashboard
# read source). dashboard/db.py only reads from Postgres when VERCEL=1 is
# also set — Vercel sets that automatically, so Hetzner's own dashboard keeps
# using local SQLite even with this var present.
SUPABASE_DB_URL=
